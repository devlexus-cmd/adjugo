# === ADJUGO BACKEND — Configuration ===

# Base — générer la clé avec :  openssl rand -hex 32
SECRET_KEY=CHANGER-OBLIGATOIREMENT-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Démo — endpoints publics sans auth. METTRE false EN PRODUCTION.
DEMO_MODE=false
# CORS — origines autorisées séparées par des virgules
CORS_ORIGINS=https://app.adjugo.fr

# Observabilité
ENVIRONMENT=production
LOG_LEVEL=INFO
SENTRY_DSN=
# Rate limiting (Redis recommandé en multi-workers)
RATELIMIT_STORAGE_URI=memory://

# Database — SQLite en local, PostgreSQL en prod
DATABASE_URL=postgresql+psycopg2://adjugo:adjugo_password@localhost:5432/adjugo_db

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# Stockage fichiers : "s3" en prod (AWS / MinIO / Scaleway), "local" en dev
STORAGE_BACKEND=s3
S3_BUCKET=adjugo-documents
S3_REGION=eu-west-3
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret

# SMTP — laisser SMTP_HOST vide pour désactiver les emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@adjugo.fr
SMTP_PASSWORD=your-password
SMTP_FROM=Adjugo <noreply@adjugo.fr>
SMTP_TLS=true

# Secret pour déclencher les tâches cron (POST /api/admin/run-alerts via X-Cron-Secret)
CRON_SECRET=change-me-cron-secret
